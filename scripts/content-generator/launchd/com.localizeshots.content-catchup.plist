<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.localizeshots.content-catchup</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/node</string>
        <string>/Users/ivorobyev/projects/localizeshots/scripts/content-generator/catch-up.cjs</string>
    </array>

    <!-- Run on user login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Run every hour as safety net to catch missed runs -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <key>StandardOutPath</key>
    <string>/Users/ivorobyev/projects/localizeshots/scripts/content-generator/logs/catchup.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/ivorobyev/projects/localizeshots/scripts/content-generator/logs/catchup-error.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/ivorobyev/projects/localizeshots/scripts/content-generator</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <!-- Throttle to avoid running too frequently -->
    <key>ThrottleInterval</key>
    <integer>300</integer>
</dict>
</plist>
